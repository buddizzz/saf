{
  "name": "saf",
  "version": "0.1.0",
  "private": true,
  "description": "صفّ (SAF) — نظام تنظيم انتظار العملاء (MVP على Cloudflare)",
  "packageManager": "pnpm@10.33.3",
  "scripts": {
    "dev": "pnpm --parallel --filter \"./apps/*\" dev",
    "dev:api": "pnpm --filter @saf/api dev",
    "dev:web": "pnpm --filter @saf/web dev",
    "build": "pnpm --filter \"./apps/*\" build",
    "lint": "pnpm --filter \"./apps/*\" lint",
    "typecheck": "pnpm --filter \"./apps/*\" typecheck",
    "db:migrate": "pnpm --filter @saf/api db:migrate",
    "db:seed": "pnpm --filter @saf/api db:seed"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild", "workerd", "sharp", "@parcel/watcher"]
  }
}
